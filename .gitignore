# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# videos — raw masters and oversized web clips stay local (too large for GitHub).
# Small/medium web clips (<=50MB) ARE committed so they self-host on deploy.
/public/videos/raw/
/public/videos/web/footballvsIU.mp4
/public/videos/web/sequence-01.mp4
/public/videos/web/commercial/portniantic.mp4
/public/videos/web/commercial/shellshockers.mp4
/public/videos/web/commercial/thursday-live.mp4
